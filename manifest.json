{
  "manifest_version": 3,
  "name": "X Video Downloader",
  "short_name": "x-video-dl",
  "version": "1.5",
  "description": "Uses the vxTwitter API to download videos from X.",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://api.vxtwitter.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}